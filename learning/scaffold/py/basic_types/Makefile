# Makefile for Python 基础类型学习卡片

PY := python3
TARGET := main.py

.PHONY: check run clean

# 检查 Python 版本并运行
check:
	@echo "[types] Checking Python version..."
	@$(PY) --version
	@echo "[types] Running main.py..."
	@$(PY) $(TARGET)

# 仅运行
run:
	@$(PY) $(TARGET)

# 清理（预留）
clean:
	@echo "[types] Nothing to clean"
