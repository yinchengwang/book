{
  "openapi": "3.0.3",
  "info": {
    "title": "MiniVecDB REST API",
    "description": "MiniVecDB 向量数据库 REST API 规范",
    "version": "0.1.0",
    "contact": {
      "name": "MiniVecDB Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发服务器"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "健康检查",
        "description": "返回服务健康状态",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "服务健康",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "version": {
                      "type": "string",
                      "example": "0.1.0"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "就绪检查",
        "description": "检查服务是否就绪处理请求",
        "operationId": "getReady",
        "responses": {
          "200": {
            "description": "服务就绪",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ready"
                    },
                    "storage": {
                      "type": "boolean"
                    },
                    "vector_index": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/live": {
      "get": {
        "summary": "活跃检查",
        "description": "检查服务是否存活",
        "operationId": "getLive",
        "responses": {
          "200": {
            "description": "服务存活",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "alive"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus 指标",
        "description": "返回 Prometheus 格式的指标数据",
        "operationId": "getMetrics",
        "responses": {
          "200": {
            "description": "指标数据",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "minivecdb_vectors_total 1000\n"
                }
              }
            }
          }
        }
      }
    },
    "/collections": {
      "get": {
        "summary": "列出所有集合",
        "operationId": "listCollections",
        "responses": {
          "200": {
            "description": "集合列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Collection"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建集合",
        "operationId": "createCollection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "dimension"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "集合名称"
                  },
                  "dimension": {
                    "type": "integer",
                    "description": "向量维度"
                  },
                  "metric_type": {
                    "type": "string",
                    "enum": ["L2", "IP", "COSINE"],
                    "default": "L2",
                    "description": "距离度量类型"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "集合已创建",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          }
        }
      }
    },
    "/collections/{collection_id}": {
      "get": {
        "summary": "获取集合详情",
        "operationId": "getCollection",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "集合详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除集合",
        "operationId": "deleteCollection",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "集合已删除"
          }
        }
      }
    },
    "/collections/{collection_id}/vectors": {
      "post": {
        "summary": "批量插入向量",
        "operationId": "insertVectors",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["vectors"],
                "properties": {
                  "vectors": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Vector"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "向量已插入",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "inserted_count": {
                      "type": "integer"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/collections/{collection_id}/vectors/{vector_id}": {
      "get": {
        "summary": "获取向量",
        "operationId": "getVector",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vector_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "向量数据",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vector"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新向量",
        "operationId": "updateVector",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vector_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Vector"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "向量已更新"
          }
        }
      },
      "delete": {
        "summary": "删除向量",
        "operationId": "deleteVector",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vector_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "向量已删除"
          }
        }
      }
    },
    "/collections/{collection_id}/search": {
      "post": {
        "summary": "向量搜索",
        "operationId": "search",
        "parameters": [
          {
            "name": "collection_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["vector"],
                "properties": {
                  "vector": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    },
                    "description": "查询向量"
                  },
                  "top_k": {
                    "type": "integer",
                    "default": 10,
                    "description": "返回结果数量"
                  },
                  "filter": {
                    "type": "object",
                    "description": "元数据过滤条件"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "搜索结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SearchResult"
                      }
                    },
                    "took_ms": {
                      "type": "number",
                      "description": "查询耗时（毫秒）"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Collection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "dimension": {
            "type": "integer"
          },
          "metric_type": {
            "type": "string",
            "enum": ["L2", "IP", "COSINE"]
          },
          "vector_count": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "integer"
          }
        }
      },
      "Vector": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "vector": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "metadata": {
            "type": "object",
            "description": "元数据键值对"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "description": "相似度得分"
          },
          "vector": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
