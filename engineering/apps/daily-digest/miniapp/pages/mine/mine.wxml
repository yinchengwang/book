<view class="mine-page">
  <text class="page-title">我的</text>

  <view class="menu-list">
    <view class="menu-item" bindtap="goSubscriptions">
      <text>订阅管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goHistory">
      <text>阅读历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="settings-section">
    <text class="section-title">主题切换</text>
    <view class="theme-options">
      <view
        class="theme-btn {{currentTheme === 'light' ? 'active' : ''}}"
        data-theme="light"
        bindtap="setTheme"
      >浅色</view>
      <view
        class="theme-btn {{currentTheme === 'dark' ? 'active' : ''}}"
        data-theme="dark"
        bindtap="setTheme"
      >暗色</view>
      <view
        class="theme-btn {{currentTheme === 'eye' ? 'active' : ''}}"
        data-theme="eye"
        bindtap="setTheme"
      >护眼</view>
      <view
        class="theme-btn {{currentTheme === 'warm' ? 'active' : ''}}"
        data-theme="warm"
        bindtap="setTheme"
      >暖色</view>
    </view>
  </view>

  <view class="about-section">
    <text class="about-text">DailyDigest v0.1.0</text>
  </view>
</view>
